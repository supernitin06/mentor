model Parent {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  parentimage String?
  age       Int
  gender    String
  phone     String?
  address   String?
  role      Role      @default(PARENT)
  students  Student[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
