model Lesson {
    id        String   @id @default(uuid())
    name      String   @unique
    description String
    mentorId String
    mentor Mentor @relation(fields: [mentorId], references: [id] , onDelete: Cascade)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    sessions Session[]
    lessonAssigns LessonAssign[]
}